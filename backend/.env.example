# Copy this to .env and fill in the values

# App
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=generate-with-openssl-rand-base64-64

# CORS — comma-separated origins
ALLOWED_ORIGINS=https://project-midnight.dev

# Database
DATABASE_URL=postgresql+asyncpg://midnight_user:your_password@localhost:5432/midnight_db

# Admin (single admin — no user registration)
ADMIN_USERNAME=admin
# Generate with: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your_password'))"
ADMIN_PASSWORD_HASH=

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Email notifications (optional — for contact form alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=
